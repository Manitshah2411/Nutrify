APP_ENV=development
FLASK_DEBUG=1
SECRET_KEY=replace-with-a-long-random-secret
GOOGLE_API_KEY=replace-with-your-google-ai-studio-key
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_REQUEST_TIMEOUT_SECONDS=8
# Use PostgreSQL in production.
DATABASE_URL=sqlite:///database.db
CORS_ORIGINS=http://localhost:5000
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_HOURS=12
RATELIMIT_STORAGE_URL=
RATELIMIT_ENABLED=1
LOG_LEVEL=INFO
LOG_FILE=
ENABLE_PROXY_FIX=1
WTF_CSRF_TIME_LIMIT=3600
MAX_CONTENT_LENGTH=16777216
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_USE_LIFO=1
SQLALCHEMY_POOL_RECYCLE=1800
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_THREADS=4
WEB_CONCURRENCY=2
DEFAULT_SCHOOL_USERNAME=BestSchool
DEFAULT_SCHOOL_NAME=The Best School
DEFAULT_SCHOOL_PASSWORD=school123
SHOW_DEMO_CREDENTIALS=1
